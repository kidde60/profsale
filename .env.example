# Frontend Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
API_BASE_URL=https://profsale.dangotechconcepts.com/api
API_TIMEOUT=30000

# App Configuration
APP_NAME=ProfSale
APP_VERSION=1.0.0
BUILD_NUMBER=1

# Environment
NODE_ENV=production

# Feature Flags
ENABLE_BARCODE_SCANNER=true
ENABLE_OFFLINE_MODE=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
ENABLE_BIOMETRIC_AUTH=true

# Business Configuration
DEFAULT_CURRENCY=UGX
DEFAULT_TIMEZONE=Africa/Kampala

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Cache Configuration
CACHE_TTL=300000
MAX_CACHE_SIZE=100

# Sync Configuration
SYNC_INTERVAL=60000
SYNC_BATCH_SIZE=50
MAX_SYNC_RETRIES=3

# Security
SESSION_TIMEOUT=3600000
TOKEN_REFRESH_THRESHOLD=300000

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_SAMPLING_RATE=1.0

# Logging
LOG_LEVEL=info
LOG_TO_CONSOLE=true
LOG_TO_FILE=false
